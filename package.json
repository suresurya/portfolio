{
  "name": "suryaportfolio",
  "author": "suresurya",
  "description": "Personal developer portfolio for Surya (vathsav) built with React, TypeScript, Vite, and Tailwind CSS.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://suresurya.github.io/portfolio/",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:gh": "tsc -b && vite build --base=/portfolio/",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "ci": "npm run lint && npm run build && npm run test:run",
    "preview": "vite preview",
    "predeploy": "npm run build:gh",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@tailwindcss/vite": "^4.1.18",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "gh-pages": "^6.3.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-github-calendar": "^5.0.4",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.5.0",
    "react-router": "^7.11.0",
    "react-tooltip": "^5.30.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.4"
  }
}
